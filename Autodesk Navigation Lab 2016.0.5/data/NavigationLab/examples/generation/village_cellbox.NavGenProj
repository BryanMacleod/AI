	<doBuild>TRUE</doBuild>
	<geometries>
		<geometry>
			<filepath>../../obj/Village_250x200_multisector/Village_250x200_Sector_C.obj</filepath>
			<counterClockWise>TRUE</counterClockWise>
		</geometry>
	</geometries>
	<cellBox>

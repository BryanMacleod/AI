		<geometry>
			<filepath>../../obj/Village_250x200_multisector/Village_250x200_Sector_B.obj</filepath>
			<counterClockWise>TRUE</counterClockWise>
		</geometry>
	</geometries>
	<cellBox>
		<min x="-1" y="1"></min>
		<max x="12" y="12"></max>
	</cellBox>
</sector>
<sector>
	<name></name>
